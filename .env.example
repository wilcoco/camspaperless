# ===== 필수 =====
# Postgres 접속 URL (Railway Postgres 플러그인이 자동 주입하는 값 사용)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# CAMS ERP 로그인 API Key (담당자에게 발급) — 절대 코드에 넣지 말 것
CAMS_API_KEY=발급받은_키

# JWT 서명 비밀키 (임의의 긴 랜덤 문자열)
JWT_SECRET=change-me-to-a-long-random-string

# 관리자 사번 목록 (콤마 구분). 이 사번으로 로그인하면 관리자 권한 부여.
ADMIN_EMPLOYEE_IDS=103485,100001

# ===== 선택 =====
# 서버 시간대 (점검 주기 날짜 계산 기준)
TZ=Asia/Seoul

# 포트 (Railway가 자동 주입)
PORT=3000

# CAMS 로그인 API 엔드포인트 (기본값 사용 시 생략 가능)
CAMS_LOGIN_URL=https://selfservice.icams.co.kr/api/erp/login

# ===== 이미지 저장소 =====
# db  = PostgreSQL에 저장 (기본값, 추가 설정 불필요)
# s3  = Cloudflare R2 등 S3 호환 스토리지 사용
STORAGE_DRIVER=db

# STORAGE_DRIVER=s3 일 때만 필요
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=camspaperless
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=https://your-public-r2-domain.example.com
